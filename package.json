{
  "name": "veto-vscode",
  "displayName": "Veto MCP Dashboard",
  "description": "Live dashboard for the Veto MCP server",
  "version": "1.0.0",
  "publisher": "jigyasudham",
  "engines": {
    "vscode": "^1.97.0",
    "node": ">=22"
  },
  "icon": "icons/veto.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jigyasudham/veto-vscode.git"
  },
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "veto",
    "mcp",
    "ai",
    "claude",
    "gemini",
    "dashboard"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veto-sidebar",
          "title": "Veto",
          "icon": "icons/veto.svg"
        }
      ]
    },
    "views": {
      "veto-sidebar": [
        {
          "id": "veto-hud",
          "name": "Veto HUD",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "veto.openHud",
        "title": "Veto: Open HUD",
        "icon": "$(dashboard)"
      },
      {
        "command": "veto.refresh",
        "title": "Veto: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "veto.searchMemory",
        "title": "Veto: Search Memory",
        "icon": "$(search)"
      },
      {
        "command": "veto.openLog",
        "title": "Veto: Open Log",
        "icon": "$(output)"
      },
      {
        "command": "veto.saveSession",
        "title": "Veto: Save Session",
        "icon": "$(save)"
      },
      {
        "command": "veto.continueSession",
        "title": "Veto: Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "veto.councilDebate",
        "title": "Veto: Council Debate",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "veto.reviewFile",
        "title": "Veto: Review Current File",
        "icon": "$(shield)"
      },
      {
        "command": "veto.reviewPR",
        "title": "Veto: Review Current PR Branch",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "veto.scanSecrets",
        "title": "Veto: Scan Project for Secrets",
        "icon": "$(key)"
      },
      {
        "command": "veto.openInstallDocs",
        "title": "Veto: Open Install Docs",
        "icon": "$(link-external)"
      },
      {
        "command": "veto.copySessionId",
        "title": "Veto: Copy Session ID",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "veto.refresh",
          "when": "view == veto-hud",
          "group": "navigation@1"
        },
        {
          "command": "veto.searchMemory",
          "when": "view == veto-hud",
          "group": "navigation@2"
        },
        {
          "command": "veto.saveSession",
          "when": "view == veto-hud",
          "group": "navigation@3"
        },
        {
          "command": "veto.openLog",
          "when": "view == veto-hud",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "veto.continueSession",
          "when": "false"
        },
        {
          "command": "veto.copySessionId",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Veto",
      "properties": {
        "veto.pollInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "How often (in milliseconds) the Veto HUD polls the database as a fallback. The HUD also updates instantly via a file watcher. Minimum 1000ms.",
          "scope": "window"
        },
        "veto.dbPath": {
          "type": "string",
          "default": "",
          "description": "Override the Veto database path. Leave empty to use the default ~/.veto/veto.db.",
          "scope": "machine"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
